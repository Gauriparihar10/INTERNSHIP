<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Internship Certificate – Deepak Kumar</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet"/>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{
    min-height:100vh;
    background:#EBEBEB;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:32px 16px;
    font-family:'DM Sans',sans-serif;
  }
  .card{
    background:#ffffff;
    border-radius:20px;
    padding:48px 40px 40px;
    max-width:440px;
    width:100%;
    text-align:center;
    box-shadow:0 4px 24px rgba(0,0,0,0.10);
  }
  h1{
    font-family:'Playfair Display',serif;
    font-size:26px;
    font-weight:700;
    text-decoration:underline;
    text-underline-offset:5px;
    color:#111;
    margin-bottom:28px;
  }
  .icon-wrap{
    margin:0 auto 28px;
    width:96px;
    height:88px;
  }
  .body-text{
    font-size:16px;
    color:#444;
    line-height:1.75;
    margin-bottom:24px;
  }
  .body-text strong{
    color:#111;
    font-weight:500;
  }
  .bottom-text{
    font-size:14px;
    color:#888;
  }
  .bottom-text a{
    color:#2563EB;
    text-decoration:underline;
    font-weight:500;
  }
  @media(max-width:480px){
    .card{padding:36px 24px 32px}
    h1{font-size:22px}
  }
</style>
</head>
<body>
<div class="card">
  <h1>Internship Certificate</h1>
  <div class="icon-wrap">
    <svg viewBox="0 0 96 88" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- frame -->
      <rect x="4" y="4" width="68" height="56" rx="5" fill="#F5A623"/>
      <!-- paper -->
      <rect x="10" y="10" width="56" height="44" rx="3" fill="#E8E8E8"/>
      <!-- lines -->
      <rect x="20" y="20" width="32" height="4" rx="2" fill="#B0B0B0"/>
      <rect x="20" y="29" width="24" height="3" rx="1.5" fill="#C5C5C5"/>
      <rect x="20" y="36" width="18" height="3" rx="1.5" fill="#D0D0D0"/>
      <!-- avatar -->
      <circle cx="50" cy="30" r="7" fill="#AAAAAA"/>
      <ellipse cx="50" cy="44" rx="9" ry="5" fill="#AAAAAA"/>
      <!-- medal -->
      <circle cx="64" cy="52" r="12" fill="#E05A5A"/>
      <circle cx="64" cy="52" r="8.5" fill="#F07575"/>
      <rect x="60" y="62" width="8" height="14" rx="1.5" fill="#E05A5A"/>
      <polygon points="60,62 64,67 68,62" fill="#C04040"/>
      <!-- star on medal -->
      <polygon points="64,47 65.4,51 69.5,51 66.2,53.5 67.5,57.5 64,55 60.5,57.5 61.8,53.5 58.5,51 62.6,51" fill="#FFD700" opacity="0.9"/>
    </svg>
  </div>
  <p class="body-text">
    This certificate is issued to <strong>Deepak Kumar</strong> for
    successfully completing the <strong>Ethical Hacking Internship</strong>
    at <strong>Internship Studio</strong>.
  </p>
  <p class="bottom-text">
    To download your certificate, please
    <a href="https://internshipstudio.com" target="_blank" rel="noopener">login</a>.
  </p>
</div>
</body>
</html>
